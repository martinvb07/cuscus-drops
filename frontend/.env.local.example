# ─────────────────────────────────────────────────────────────────────────────
# CUSCUS HATS — Variables de entorno
# Copia este archivo como .env.local y completa los valores reales
# NUNCA subas .env.local a git (ya está en .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# ── Shopify Storefront API (público — usado en el frontend) ───────────────────
# Cómo obtenerlos:
#   Shopify Admin → Apps → Develop apps → Create app
#   En "Configuration" habilita Storefront API con scopes:
#     - unauthenticated_read_product_listings
#     - unauthenticated_read_checkouts
#     - unauthenticated_write_checkouts
#   Instala la app → Storefront API → copia el "Storefront API access token"

SHOPIFY_STORE_DOMAIN=tu-tienda.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=tu_storefront_token_aqui
SHOPIFY_VARIANT_ID=gid://shopify/ProductVariant/TU_VARIANT_ID_AQUI

# ── Shopify Admin API (secreto — SOLO servidor, nunca NEXT_PUBLIC_) ───────────
# Cómo obtenerlo:
#   Shopify Admin → Apps → Develop apps → tu app → Admin API access token
#   Scopes necesarios: read_orders, read_customers, read_inventory, read_products
# IMPORTANTE: este token nunca se expone al browser. Solo se usa en route handlers.

SHOPIFY_ADMIN_TOKEN=shpat_TU_ADMIN_TOKEN_AQUI

# ── Precio a mostrar (solo display, el precio real viene de Shopify) ──────────
PRODUCT_PRICE=150.000
PRODUCT_CURRENCY=COP

# ── Panel Admin ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4001
NEXT_PUBLIC_ADMIN_PASSWORD=tu_password_seguro_aqui
# Misma contraseña sin NEXT_PUBLIC (verificación server-side en API routes)
ADMIN_PASSWORD=tu_password_seguro_aqui
# URL del backend para tracking interno (server-side)
BACKEND_URL=http://localhost:4001
