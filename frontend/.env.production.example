# ─────────────────────────────────────────────────────────────────────────────
# CUSCUS HATS — ENV PRODUCCIÓN
# Copiar como .env.local en el VPS y completar los valores
# ─────────────────────────────────────────────────────────────────────────────

# ── Shopify Admin API (SOLO servidor — no exponer) ────────────────────────────
SHOPIFY_STORE_DOMAIN=gzqyqr-0k.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SHOPIFY_VARIANT_ID=gid://shopify/ProductVariant/44148658929752

# ── Shopify Storefront API (token público — para checkout headless) ───────────
# Obtener: Shopify Admin → Apps → Headless → Storefront API access token
SHOPIFY_STOREFRONT_TOKEN=shpst_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Dominio checkout producción ───────────────────────────────────────────────
SHOPIFY_CHECKOUT_DOMAIN=payments.cuscushats.com

# ── Site URL producción ───────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://cuscushats.com

# ── Stock ─────────────────────────────────────────────────────────────────────
PRODUCT_PRICE=210.000
PRODUCT_CURRENCY=COP
STOCK_TOTAL=100

# ── Backend producción ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.cuscushats.com
BACKEND_URL=https://api.cuscushats.com

# ── Admin ─────────────────────────────────────────────────────────────────────
# IMPORTANTE: cambiar por contraseña segura antes de producción
ADMIN_PASSWORD=CAMBIAR_POR_CONTRASEÑA_SEGURA
